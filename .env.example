# ── Django ──
SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.local

# ── Database ──
DATABASE_URL=postgres://autoflow:autoflow@db:5432/autoflow
DB_NAME=autoflow
DB_USER=autoflow
DB_PASSWORD=autoflow
DB_HOST=db
DB_PORT=5432

# ── JWT ──
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# ── CORS ──
CORS_ALLOWED_ORIGINS=chrome-extension://your-extension-id,http://localhost:3000

# ── Email ──
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@autoflow.app

# ── Email Verification ──
VERIFY_EMAIL_BASE_URL=http://localhost:3000/verify-email
VERIFICATION_TOKEN_EXPIRY_HOURS=24

# ── Whop ──
WHOP_WEBHOOK_SECRET=change-me

# ── Free Plan ──
FREE_DAILY_PROMPT_LIMIT=30
